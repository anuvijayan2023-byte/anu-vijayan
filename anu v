<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Anu Vijayan | Assistant Professor of English</title>
    <!-- Tailwind CSS for modern styling -->
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <!-- Font Awesome for academic icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Google Fonts: Playfair Display for a literary feel -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Lora:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --academic-blue: #1e293b;
            --paper-white: #f8fafc;
        }
        
        body {
            font-family: 'Lora', serif;
            background-color: var(--paper-white);
            color: #334155;
        }

        h1, h2, h3, nav a {
            font-family: 'Playfair Display', serif;
        }

        .hero-section {
            background-color: #ffffff;
            border-bottom: 1px solid #e2e8f0;
        }

        .qualification-card {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .qualification-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
        }

        .sidebar-border {
            border-left: 4px solid #1e293b;
        }
    </style>
</head>
<body class="antialiased">

    <!-- Header / Navigation -->
    <header class="sticky top-0 z-50 bg-white/90 backdrop-blur-sm border-b border-slate-200">
        <div class="max-w-5xl mx-auto px-6 py-4 flex justify-between items-center">
            <div class="text-2xl font-bold text-slate-900 tracking-tight">
                Anu Vijayan <span class="text-sm font-normal text-slate-500 ml-2">MA, BEd, SET</span>
            </div>
            <nav class="hidden md:flex space-x-8 text-sm font-medium">
                <a href="#about" class="text-slate-600 hover:text-slate-900 transition">About</a>
                <a href="#education" class="text-slate-600 hover:text-slate-900 transition">Education</a>
                <a href="#specialization" class="text-slate-600 hover:text-slate-900 transition">Specialization</a>
                <a href="#contact" class="px-4 py-2 bg-slate-900 text-white rounded hover:bg-slate-800 transition">Contact</a>
            </nav>
        </div>
    </header>

    <main>
        <!-- Hero / Intro -->
        <section class="hero-section py-20 px-6">
            <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center gap-12">
                <div class="md:w-2/3">
                    <h2 class="text-blue-600 font-semibold tracking-widest uppercase text-sm mb-4">Faculty Portfolio</h2>
                    <h1 class="text-5xl md:text-6xl font-bold text-slate-900 leading-tight mb-6">
                        Anu Vijayan
                    </h1>
                    <p class="text-2xl text-slate-700 italic mb-8">
                        Assistant Professor in English Language & Literature
                    </p>
                    <div class="sidebar-border pl-6 py-2 mb-10">
                        <p class="text-lg text-slate-600 leading-relaxed max-w-2xl">
                            Dedicated educator and scholar with a profound interest in the intersection of classical literature and modern linguistic pedagogy. Committed to cultivating critical thinking and literary appreciation in the higher education landscape.
                        </p>
                    </div>
                    <div class="flex gap-4">
                        <a href="#contact" class="inline-block bg-slate-900 text-white px-8 py-3 rounded-lg font-medium shadow-lg hover:shadow-xl transition">Connect Professionally</a>
                    </div>
                </div>
                <div class="md:w-1/3 flex justify-center">
                    <div class="w-64 h-80 bg-slate-200 rounded-lg relative overflow-hidden shadow-2xl rotate-2 hover:rotate-0 transition-all duration-500">
                        <!-- Placeholder for Professional Photo -->
                        <img src="https://images.unsplash.com/photo-1491843384429-171f1f2079da?auto=format&fit=crop&q=80&w=800" alt="Literature and Education" class="w-full h-full object-cover">
                        <div class="absolute inset-0 bg-slate-900/10 hover:bg-transparent transition-colors"></div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Academic Credentials -->
        <section id="education" class="py-20 px-6 bg-slate-50">
            <div class="max-w-5xl mx-auto">
                <div class="text-center mb-16">
                    <h2 class="text-3xl font-bold text-slate-900 mb-4">Academic Qualifications</h2>
                    <div class="w-16 h-1 bg-blue-600 mx-auto"></div>
                </div>
                
                <div class="grid md:grid-cols-3 gap-8">
                    <!-- MA -->
                    <div class="qualification-card bg-white p-8 rounded-xl border border-slate-200 text-center">
                        <div class="w-14 h-14 bg-blue-50 text-blue-700 rounded-full flex items-center justify-center mx-auto mb-6">
                            <i class="fa-solid fa-graduation-cap text-2xl"></i>
                        </div>
                        <h3 class="text-xl font-bold mb-2">MA English</h3>
                        <p class="text-slate-500 text-sm mb-4 italic">Postgraduate Degree</p>
                        <p class="text-slate-600 text-sm">Advanced study in English Language and Literature, exploring diverse literary periods and critical theories.</p>
                    </div>

                    <!-- BEd -->
                    <div class="qualification-card bg-white p-8 rounded-xl border border-slate-200 text-center">
                        <div class="w-14 h-14 bg-green-50 text-green-700 rounded-full flex items-center justify-center mx-auto mb-6">
                            <i class="fa-solid fa-chalkboard-user text-2xl"></i>
                        </div>
                        <h3 class="text-xl font-bold mb-2">BEd</h3>
                        <p class="text-slate-500 text-sm mb-4 italic">Bachelor of Education</p>
                        <p class="text-slate-600 text-sm">Focused on pedagogical methodologies, educational psychology, and innovative teaching techniques.</p>
                    </div>

                    <!-- SET -->
                    <div class="qualification-card bg-white p-8 rounded-xl border border-slate-200 text-center">
                        <div class="w-14 h-14 bg-amber-50 text-amber-700 rounded-full flex items-center justify-center mx-auto mb-6">
                            <i class="fa-solid fa-award text-2xl"></i>
                        </div>
                        <h3 class="text-xl font-bold mb-2">SET</h3>
                        <p class="text-slate-500 text-sm mb-4 italic">State Eligibility Test</p>
                        <p class="text-slate-600 text-sm">Professional certification qualifying eligibility for higher secondary and collegiate level teaching.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Research/Interests -->
        <section id="specialization" class="py-20 px-6 bg-white">
            <div class="max-w-5xl mx-auto flex flex-col md:flex-row gap-16 items-center">
                <div class="md:w-1/2">
                    <img src="https://images.unsplash.com/photo-1456513080510-7bf3a84b82f8?auto=format&fit=crop&q=80&w=800" class="rounded-2xl shadow-xl" alt="Books and Study">
                </div>
                <div class="md:w-1/2">
                    <h2 class="text-3xl font-bold mb-6">Teaching & Academic Interests</h2>
                    <p class="text-slate-600 mb-8 leading-relaxed">
                        My primary academic focus is on bridging the gap between historical literature and contemporary communication. I am passionate about:
                    </p>
                    <ul class="space-y-4">
                        <li class="flex items-center gap-3">
                            <span class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-slate-900 font-bold text-xs italic">01</span>
                            <span class="text-slate-800 font-medium">British & World Literature</span>
                        </li>
                        <li class="flex items-center gap-3">
                            <span class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-slate-900 font-bold text-xs italic">02</span>
                            <span class="text-slate-800 font-medium">English Language Teaching (ELT)</span>
                        </li>
                        <li class="flex items-center gap-3">
                            <span class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-slate-900 font-bold text-xs italic">03</span>
                            <span class="text-slate-800 font-medium">Linguistic Theory & Discourse</span>
                        </li>
                        <li class="flex items-center gap-3">
                            <span class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-slate-900 font-bold text-xs italic">04</span>
                            <span class="text-slate-800 font-medium">Cultural Studies & Theory</span>
                        </li>
                    </ul>
                </div>
            </div>
        </section>

        <!-- Contact Section -->
        <section id="contact" class="py-24 px-6 bg-slate-900 text-white">
            <div class="max-w-3xl mx-auto text-center">
                <h2 class="text-4xl font-bold mb-8 italic">Get in Touch</h2>
                <p class="text-slate-400 mb-12 text-lg">
                    Whether you are a student, a fellow academic, or interested in collaborative research, I welcome your correspondence.
                </p>
                
                <div class="grid md:grid-cols-2 gap-6 mb-12">
                    <div class="bg-slate-800/50 p-6 rounded-lg border border-slate-700">
                        <i class="fa-solid fa-envelope text-blue-400 mb-3 text-xl"></i>
                        <h4 class="font-bold mb-1">Email Address</h4>
                        <p class="text-slate-400 text-sm">anu.vijayan@university.edu</p>
                    </div>
                    <div class="bg-slate-800/50 p-6 rounded-lg border border-slate-700">
                        <i class="fa-solid fa-location-dot text-blue-400 mb-3 text-xl"></i>
                        <h4 class="font-bold mb-1">Office Location</h4>
                        <p class="text-slate-400 text-sm">Department of English</p>
                    </div>
                </div>

                <div class="flex justify-center space-x-6">
                    <a href="#" class="text-slate-400 hover:text-white transition text-2xl"><i class="fa-brands fa-linkedin"></i></a>
                    <a href="#" class="text-slate-400 hover:text-white transition text-2xl"><i class="fa-brands fa-google-scholar"></i></a>
                    <a href="#" class="text-slate-400 hover:text-white transition text-2xl"><i class="fa-solid fa-scroll"></i></a>
                </div>
            </div>
        </section>
    </main>

    <footer class="bg-slate-950 text-slate-500 py-8 px-6 text-center text-sm">
        <p>&copy; 2026 Anu Vijayan. Professional Academic Portfolio.</p>
    </footer>

    <script>
        // Smooth scrolling for navigation
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                document.querySelector(this.getAttribute('href')).scrollIntoView({
                    behavior: 'smooth'
                });
            });
        });
    </script>
</body>
</html>
